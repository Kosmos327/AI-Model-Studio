{
  "name": "ai-model-studio-desktop",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && uvicorn app.main:app --reload --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "build:backend": "node scripts/build-backend.js",
    "build:frontend": "cd frontend && npm run build",
    "build:desktop": "npm run build:frontend && tauri build",
    "generate:icons": "python scripts/generate-icons.py",
    "tauri": "tauri",
    "tauri:dev": "npm run build:backend && npm run build:frontend && tauri dev"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  }
}
